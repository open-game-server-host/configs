{
    "configVersion": 1,
    "api": {
        "maxPaginatedResults": 100,
        "appArchiveDownloadNoProgressTimeoutSeconds": 30
    },
    "container": {
        "maxNameLength": 30,
        "runtimesDockerRegistryUrlStub": "ghcr.io/open-game-server-host/container-runtimes/"
    },
    "daemon": {
        "websocketReconnectSeconds": 3,
        "websocketEventPushFrequencyMs": 1000,
        "cooldownSecondsBetweenPullingSameDockerImage": 60,
        "appInstallerImageWithBranch": "ghcr.io/open-game-server-host/app-installer:main",
        "runtimeImagesBranch": "main",
        "dockerRegistryAuthUrl": "TODO",
        "container": {
            "stopTimeoutSeconds": 120,
            "maxConcurrentInstalls": 2,
            "maxWebsocketConnectionsPerContainerPerUser": 3,
            "actionQueueMaxLength": 3,
            "previousLogsToSendOnWebsocketConnect": 30,
            "secondsBetweenStorageCalculations": 3
        }
    }
}